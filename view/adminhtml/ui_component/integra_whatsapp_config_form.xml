<?xml version="1.0" encoding="UTF-8"?>
<form xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">integra_whatsapp_config_form.integra_whatsapp_config_form_data_source</item>
            <item name="deps" xsi:type="string">integra_whatsapp_config_form.integra_whatsapp_config_form_data_source</item>
        </item>
        <item name="label" xsi:type="string" translate="true">General Information</item>
        <item name="config" xsi:type="array">
            <item name="dataScope" xsi:type="string">data</item>
            <item name="namespace" xsi:type="string">integra_whatsapp_config_form</item>
        </item>
        <item name="template" xsi:type="string">templates/form/collapsible</item>
        <item name="buttons" xsi:type="array">
            <item name="back" xsi:type="string">Integra\Whatsapp\Block\Adminhtml\Config\Edit\BackButton</item>
            <item name="delete" xsi:type="string">Integra\Whatsapp\Block\Adminhtml\Config\Edit\DeleteButton</item>
            <item name="send_test_message" xsi:type="string">Integra\Whatsapp\Block\Adminhtml\Config\Edit\TestMessageButton</item>
            <item name="save" xsi:type="string">Integra\Whatsapp\Block\Adminhtml\Config\Edit\SaveButton</item>
        </item>
    </argument>
    <dataSource name="integra_whatsapp_config_form_data_source">
        <argument name="dataProvider" xsi:type="configurableObject">
            <argument name="class" xsi:type="string">Integra\Whatsapp\Model\Config\DataProvider</argument>
            <argument name="name" xsi:type="string">integra_whatsapp_config_form_data_source</argument>
            <argument name="primaryFieldName" xsi:type="string">entity_id</argument>
            <argument name="requestFieldName" xsi:type="string">entity_id</argument>
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="submit_url" xsi:type="url" path="integrawhatsapp/config/save"/>
                </item>
            </argument>
        </argument>
        <argument name="data" xsi:type="array">
            <item name="js_config" xsi:type="array">
                <item name="component" xsi:type="string">Magento_Ui/js/form/provider</item>
            </item>
        </argument>
    </dataSource>
    <fieldset name="general">
        <argument name="data" xsi:type="array">
            <item name="config" xsi:type="array">
                <item name="label" xsi:type="string"/>
            </item>
        </argument>
        <field name="entity_id">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="visible" xsi:type="boolean">false</item>
                    <item name="dataType" xsi:type="string">text</item>
                    <item name="formElement" xsi:type="string">hidden</item>
                    <item name="source" xsi:type="string">config</item>
                    <item name="dataScope" xsi:type="string">entity_id</item>
                </item>
            </argument>
        </field>
        <field name="is_active">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="dataType" xsi:type="string">boolean</item>
                    <item name="label" xsi:type="string" translate="true">Módulo Ativo</item>
                    <item name="formElement" xsi:type="string">checkbox</item>
                    <item name="prefer" xsi:type="string">toggle</item>
                    <item name="source" xsi:type="string">config</item>
                    <item name="sortOrder" xsi:type="number">10</item>
                    <item name="dataScope" xsi:type="string">is_active</item>
                    <item name="valueMap" xsi:type="array">
                        <item name="true" xsi:type="number">1</item>
                        <item name="false" xsi:type="number">0</item>
                    </item>
                    <item name="default" xsi:type="number">1</item>
                </item>
            </argument>
        </field>
        <field name="name">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="dataType" xsi:type="string">text</item>
                    <item name="label" xsi:type="string" translate="true">Nome da Configuração</item>
                    <item name="formElement" xsi:type="string">input</item>
                    <item name="source" xsi:type="string">config</item>
                    <item name="sortOrder" xsi:type="number">20</item>
                    <item name="dataScope" xsi:type="string">name</item>
                    <item name="validation" xsi:type="array">
                        <item name="required-entry" xsi:type="boolean">true</item>
                    </item>
                </item>
            </argument>
        </field>
        <field name="api_provider">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="dataType" xsi:type="string">text</item>
                    <item name="label" xsi:type="string" translate="true">API de Integração</item>
                    <item name="formElement" xsi:type="string">radios</item>
                    <item name="source" xsi:type="string">config</item>
                    <item name="sortOrder" xsi:type="number">25</item>
                    <item name="dataScope" xsi:type="string">api_provider</item>
                    <item name="default" xsi:type="string">facebook</item>
                    <item name="options" xsi:type="array">
                        <item name="0" xsi:type="array">
                            <item name="value" xsi:type="string">facebook</item>
                            <item name="label" xsi:type="string" translate="true">Facebook</item>
                        </item>
                        <item name="1" xsi:type="array">
                            <item name="value" xsi:type="string">zapi</item>
                            <item name="label" xsi:type="string" translate="true">Z-API</item>
                        </item>
                    </item>
                </item>
            </argument>
        </field>
        <field name="test_phone">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="dataType" xsi:type="string">text</item>
                    <item name="label" xsi:type="string" translate="true">Telefone para Teste</item>
                    <item name="formElement" xsi:type="string">input</item>
                    <item name="source" xsi:type="string">config</item>
                    <item name="sortOrder" xsi:type="number">26</item>
                    <item name="dataScope" xsi:type="string">test_phone</item>
                </item>
            </argument>
        </field>
        <field name="test_message">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="dataType" xsi:type="string">text</item>
                    <item name="label" xsi:type="string" translate="true">Mensagem de Teste</item>
                    <item name="formElement" xsi:type="string">textarea</item>
                    <item name="source" xsi:type="string">config</item>
                    <item name="sortOrder" xsi:type="number">27</item>
                    <item name="dataScope" xsi:type="string">test_message</item>
                    <item name="default" xsi:type="string">Teste de integração WhatsApp</item>
                </item>
            </argument>
        </field>
    </fieldset>
    <fieldset name="facebook">
        <argument name="data" xsi:type="array">
            <item name="config" xsi:type="array">
                <item name="label" xsi:type="string" translate="true">Facebook (WhatsApp Cloud API)</item>
                <item name="collapsible" xsi:type="boolean">true</item>
                <item name="opened" xsi:type="boolean">true</item>
            </item>
        </argument>
        <field name="phone_number_id">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="dataType" xsi:type="string">text</item>
                    <item name="label" xsi:type="string" translate="true">Phone Number ID</item>
                    <item name="formElement" xsi:type="string">input</item>
                    <item name="source" xsi:type="string">config</item>
                    <item name="sortOrder" xsi:type="number">10</item>
                    <item name="dataScope" xsi:type="string">phone_number_id</item>
                </item>
            </argument>
        </field>
        <field name="business_account_id">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="dataType" xsi:type="string">text</item>
                    <item name="label" xsi:type="string" translate="true">Business Account ID</item>
                    <item name="formElement" xsi:type="string">input</item>
                    <item name="source" xsi:type="string">config</item>
                    <item name="sortOrder" xsi:type="number">20</item>
                    <item name="dataScope" xsi:type="string">business_account_id</item>
                </item>
            </argument>
        </field>
        <field name="access_token">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="dataType" xsi:type="string">text</item>
                    <item name="label" xsi:type="string" translate="true">Access Token</item>
                    <item name="formElement" xsi:type="string">textarea</item>
                    <item name="source" xsi:type="string">config</item>
                    <item name="sortOrder" xsi:type="number">30</item>
                    <item name="dataScope" xsi:type="string">access_token</item>
                </item>
            </argument>
        </field>
        <field name="facebook_api_version">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="dataType" xsi:type="string">text</item>
                    <item name="label" xsi:type="string" translate="true">Facebook API Version</item>
                    <item name="formElement" xsi:type="string">input</item>
                    <item name="source" xsi:type="string">config</item>
                    <item name="sortOrder" xsi:type="number">40</item>
                    <item name="dataScope" xsi:type="string">facebook_api_version</item>
                    <item name="default" xsi:type="string">v23.0</item>
                </item>
            </argument>
        </field>
    </fieldset>
    <fieldset name="zapi">
        <argument name="data" xsi:type="array">
            <item name="config" xsi:type="array">
                <item name="label" xsi:type="string" translate="true">Z-API</item>
                <item name="collapsible" xsi:type="boolean">true</item>
                <item name="opened" xsi:type="boolean">true</item>
            </item>
        </argument>
        <field name="zapi_instance_id">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="dataType" xsi:type="string">text</item>
                    <item name="label" xsi:type="string" translate="true">Instance ID</item>
                    <item name="formElement" xsi:type="string">input</item>
                    <item name="source" xsi:type="string">config</item>
                    <item name="sortOrder" xsi:type="number">10</item>
                    <item name="dataScope" xsi:type="string">zapi_instance_id</item>
                </item>
            </argument>
        </field>
        <field name="zapi_token">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="dataType" xsi:type="string">text</item>
                    <item name="label" xsi:type="string" translate="true">Token</item>
                    <item name="formElement" xsi:type="string">input</item>
                    <item name="source" xsi:type="string">config</item>
                    <item name="sortOrder" xsi:type="number">20</item>
                    <item name="dataScope" xsi:type="string">zapi_token</item>
                </item>
            </argument>
        </field>
        <field name="zapi_client_token">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="dataType" xsi:type="string">text</item>
                    <item name="label" xsi:type="string" translate="true">Client-Token (opcional)</item>
                    <item name="formElement" xsi:type="string">input</item>
                    <item name="source" xsi:type="string">config</item>
                    <item name="sortOrder" xsi:type="number">30</item>
                    <item name="dataScope" xsi:type="string">zapi_client_token</item>
                </item>
            </argument>
        </field>
    </fieldset>
</form>
